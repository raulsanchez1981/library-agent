# Plantilla de variables de entorno para Authentik (Identity Provider)
#
# Copia este fichero a /opt/libraryagent/.env.authentik en roshar y rellena
# los valores reales. El fichero .env.authentik NUNCA se commitea al repositorio
# (está en .gitignore).
#
# Uso:
#   docker compose -f docker-compose.authentik.yml --env-file /opt/libraryagent/.env.authentik up -d

# ── Base de datos (PostgreSQL en scadrial: 192.168.1.102) ─────────────────────
# Base de datos dedicada para Authentik (crear manualmente, ver docker/authentik/SETUP.md)
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=your-authentik-db-user-here
AUTHENTIK_DB_PASSWORD=change-me

# ── Clave secreta de Authentik ────────────────────────────────────────────────
# Generar con: openssl rand -base64 60
# IMPORTANTE: una vez configurada, no cambiar (invalida todas las sesiones)
AUTHENTIK_SECRET_KEY=your-very-long-random-secret-key-here

# ── Cuenta de administrador inicial ──────────────────────────────────────────
# Solo se usa en el primer arranque para crear el superusuario
# Tras el setup inicial, cambiar la contraseña desde la UI
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-on-first-login
