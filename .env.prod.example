# ── Base de datos (PostgreSQL en scadrial: 192.168.1.102) ─────────────────────
DB_NAME=libraryagent
DB_USERNAME=libraryagent
DB_PASSWORD=change-me

# ── APIs externas ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── GitHub Actions runner ──────────────────────────────────────────────────────
# PAT con scope: repo (Settings > Developer settings > Personal access tokens)
GITHUB_ACCESS_TOKEN=your-github-pat-here

# ── Authentik OIDC (generados tras configurar Authentik) ──────────────────────
# Obtener desde Authentik UI: Applications > LibraryAgent > OAuth2/OIDC Provider
# Guardar también como GitHub Secrets: AUTHENTIK_CLIENT_ID y AUTHENTIK_CLIENT_SECRET
AUTHENTIK_CLIENT_ID=your-client-id-here
AUTHENTIK_CLIENT_SECRET=your-client-secret-here
AUTHENTIK_ISSUER_URI=https://auth.mistborn.cv/application/o/libraryagent/

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://library.mistborn.cv

# ── Dashboard Next.js ─────────────────────────────────────────────────────────
NEXTAUTH_URL=https://library.mistborn.cv
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_AUTHENTIK_ID=your-client-id-here
AUTH_AUTHENTIK_SECRET=your-client-secret-here
AUTH_AUTHENTIK_ISSUER=https://auth.mistborn.cv/application/o/libraryagent/
NEXT_PUBLIC_API_URL=https://atium.mistborn.cv/library-agent
