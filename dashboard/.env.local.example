NEXT_PUBLIC_API_URL=http://localhost:8080/library-agent

# NextAuth (Fase 4.5.2)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# Authentik OIDC (Fase 4.5.2)
AUTH_AUTHENTIK_ID=your-client-id-here
AUTH_AUTHENTIK_SECRET=your-client-secret-here
AUTH_AUTHENTIK_ISSUER=https://auth.mistborn.cv/application/o/libraryagent/
# Nota: el trailing slash es obligatorio — debe coincidir con el issuer del discovery document de Authentik
